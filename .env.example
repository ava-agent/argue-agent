# 智谱 GLM API Key (必需)
ARGUE_GLM_API_KEY=your-glm-api-key-here

# Tavily Search API Key (Vercel 部署必需，本地可不填使用 DuckDuckGo)
# https://tavily.com/ 免费 1,000 次/月
ARGUE_TAVILY_API_KEY=your-tavily-api-key-here

# Deepgram API Key (语音转文字，可选 - 注册免费获得 $200 额度)
# https://console.deepgram.com/signup
ARGUE_DEEPGRAM_API_KEY=your-deepgram-api-key-here

# 服务器配置
ARGUE_HOST=0.0.0.0
ARGUE_PORT=8000
